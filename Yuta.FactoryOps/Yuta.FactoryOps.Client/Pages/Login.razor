@using Yuta.FactoryOps.Client.Rotas
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Yuta.FactoryOps.Client.Security

@attribute [Route(ConstantesRotas.Login)]
@attribute [AllowAnonymous]
@layout EmptyLayout

@inject HttpClient Http
@inject NavigationManager Navigation
@inject ProvedorAutenticacaoJwt ProvedorAuth

<PageTitle>YUTA - Login</PageTitle>

<div class="yuta-login-container">
    <div class="yuta-login-card">

        <div class="yuta-brand">
            <h1>YUTA</h1>
            <p>Factory Operation System</p>
        </div>

        <EditForm Model="@loginModel" OnValidSubmit="ExecutarLogin">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="yuta-alert">
                    <span>⚠️</span> @mensagemErro
                </div>
            }

            <div class="form-group">
                <label for="email">Usuário / E-mail</label>
                <InputText id="email" class="input-control" @bind-Value="loginModel.Email" placeholder="nome@yuta.com" />
                <ValidationMessage For="@(() => loginModel.Email)" class="text-danger" style="font-size: 0.8rem; color: #ff7b72; margin-top: 4px; display:block;" />
            </div>

            <div class="form-group">
                <label for="password">Senha de Acesso</label>
                <InputText id="password" type="password" class="input-control" @bind-Value="loginModel.Senha" placeholder="••••••••" />
                <ValidationMessage For="@(() => loginModel.Senha)" class="text-danger" style="font-size: 0.8rem; color: #ff7b72; margin-top: 4px; display:block;" />
            </div>

            <button type="submit" class="btn-yuta-submit" disabled="@estaCarregando">
                @if (estaCarregando)
                {
                    <div class="spinner"></div> <span>Autenticando na Malha...</span>
                }
                else
                {
                    <span>CONECTAR AO SISTEMA</span>
                }
            </button>
        </EditForm>

    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? mensagemErro;
    private bool estaCarregando = false;

    private async Task ExecutarLogin()
    {
        estaCarregando = true;
        mensagemErro = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var resultado = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (resultado != null && !string.IsNullOrEmpty(resultado.Token))
                {
                    await ProvedorAuth.MarcarComoAutenticado(resultado.Token);
                    Navigation.NavigateTo("/", replace: true);
                }
                else
                {
                    mensagemErro = "Resposta de autenticação inválida.";
                }
            }
            else
            {
                mensagemErro = "Credenciais incorretas ou operador não ativo.";
            }
        }
        catch (Exception)
        {
            mensagemErro = "Falha de comunicação com o servidor de manufatura.";
        }
        finally
        {
            estaCarregando = false;
        }
    }

    public class LoginRequest
    {
        [Required(ErrorMessage = "O identificador é obrigatório.")]
        [EmailAddress(ErrorMessage = "Insira um formato de e-mail válido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "A senha é obrigatória.")]
        public string Senha { get; set; } = string.Empty;
    }

    public class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
    }
}