@page "/dashboard"
@using Yuta.FactoryOps.Application.Interfaces
@using Yuta.FactoryOps.Domain.Entities
@inject IDashboardService DashboardService

<div class="factoryops-container">

    <header class="factory-header">
        <div class="header-left">
            <span class="logo">YUTA <small>prevent</small></span>
            <span class="brand-title">FactoryOps</span>
            <div class="badge-status">Linha 1 — Planta Campinas <span class="dot-online">● ONLINE</span></div>
        </div>
        <div class="header-right">
            <button class="btn-action">⚠️ Injetar Falha</button>
            <button class="btn-action">📊 Relatório</button>
            <div class="time-display">21:37:33 <small>qua, 17/06</small></div>
        </div>
    </header>

    <div class="dashboard-grid">

        <aside class="sidebar-ativos">
            <h3>ATIVOS — LINHA 1</h3>
            @if (ativos == null)
            {
                <p class="loading-text">Carregando malha...</p>
            }
            else
            {
                @foreach (var ativo in ativos)
                {
                    <div class="ativo-card">
                        <div class="ativo-info">
                            <h4>@ativo.Nome</h4>
                            <p>@ativo.Descricao</p>
                        </div>
                        <div class="ativo-saude">
                            <div class="bar-chart">
                                @if (ativo.HistoricoSaude != null)
                                {
                                    @foreach (var nivel in ativo.HistoricoSaude)
                                    {
                                        <div class="bar" style="height: @(nivel * 10)%;"></div>
                                    }
                                }
                            </div>
                            <span class="percentage @(ativo.SaudePercentual < 80 ? "warning" : "good")">@ativo.SaudePercentual%</span>
                        </div>
                    </div>
                }
            }
        </aside>

        <main class="main-content">
            <nav class="sub-nav">
                <button class="nav-tab @(abaAtiva == "visao" ? "active" : "")" @onclick='() => AlternarAba("visao")'>Visão Geral</button>
                <button class="nav-tab @(abaAtiva == "fft" ? "active" : "")" @onclick='() => AlternarAba("fft")'>Espectro FFT</button>
                <button class="nav-tab @(abaAtiva == "manutencao" ? "active" : "")" @onclick='() => AlternarAba("manutencao")'>Manutenção</button>
                <span class="alert-badge">Alertas <span>1</span></span>
            </nav>

            @if (abaAtiva == "manutencao")
            {
                <div class="filter-bar">
                    <button class="filter-btn @(filtroAtivo == "todos" ? "active" : "")" @onclick='() => Filtrar("todos")'>Todos</button>
                    <button class="filter-btn @(filtroAtivo == "preventiva" ? "active" : "")" @onclick='() => Filtrar("preventiva")'>Preventiva</button>
                    <button class="filter-btn @(filtroAtivo == "corretiva" ? "active" : "")" @onclick='() => Filtrar("corretiva")'>Corretiva</button>
                    <button class="filter-btn @(filtroAtivo == "preditiva" ? "active" : "")" @onclick='() => Filtrar("preditiva")'>Preditiva</button>
                </div>

                <div class="timeline-container">
                    @if (manutencoes == null)
                    {
                        <p class="loading-text">Buscando ordens...</p>
                    }
                    else
                    {
                        @foreach (var manut in ObterManutencoesFiltradas())
                        {
                            <div class="timeline-card">
                                <div class="card-time">
                                    <strong>@manut.Data</strong>
                                    <span>@manut.Hora</span>
                                </div>
                                <span class="badge-tipo @manut.Tipo.ToLower()">@manut.Tipo</span>
                                <div class="card-body">
                                    <h5>@manut.Titulo</h5>
                                    <p>@manut.DetalheAtivo</p>
                                </div>
                                <div class="card-status">
                                    <span class="check-icon">✓</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="loading-text" style="padding: 40px; border: 1px dashed #23193a; border-radius: 6px; margin-top: 15px;">
                    Tela em desenvolvimento para a aba: <strong>@abaAtiva.ToUpper()</strong>
                </div>
            }
        </main>

        <aside class="sidebar-ia">
            <div class="ia-header">
                <button class="tab-ia active">Agente IA</button>
                <button class="tab-ia">Prescrições</button>
            </div>
            <div class="ia-box">
                <h4>AGENTE OMEGA <small>Edge AI + RAG</small></h4>
                <div class="ia-message">
                    <p><strong>AGENTE OMEGA:</strong> Sistema inicializado. Monitorando <strong>6 ativos</strong> — Linha 1, MetalForm Indústria, Campinas.</p>
                    <div class="ia-alert">
                        ⚠️ <strong>Atenção:</strong> detectei alertas críticos na <strong>Prensa Hidráulica PH-02</strong> — vibração elevada e temperatura de óleo acima do limiar. Recomendo diagnóstico imediato.
                    </div>
                </div>
            </div>
            <div class="ia-input-container">
                <input type="text" placeholder="Descreva sintoma ou pergunta técnica..." />
                <button class="btn-send">➔</button>
            </div>
        </aside>

    </div>
</div>

@code {
    private List<Ativo>? ativos;
    private List<Manutencao>? manutencoes;

    // Estados interativos da UI
    private string abaAtiva = "manutencao";
    private string filtroAtivo = "todos";

    protected override async Task OnInitializedAsync()
    {
        ativos = await DashboardService.ObterAtivosAsync();
        manutencoes = await DashboardService.ObterManutencoesAsync();
    }

    private void AlternarAba(string novaAba)
    {
        abaAtiva = novaAba;
    }

    private void Filtrar(string novoFiltro)
    {
        filtroAtivo = novoFiltro;
    }

    private IEnumerable<Manutencao> ObterManutencoesFiltradas()
    {
        if (manutencoes == null) return Enumerable.Empty<Manutencao>();

        if (filtroAtivo == "todos")
            return manutencoes;

        return manutencoes.Where(m => m.Tipo.Equals(filtroAtivo, StringComparison.OrdinalIgnoreCase));
    }
}