@page "/usuarios"
@layout MainLayout

@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Yuta.FactoryOps.Domain.Entities
@using System.ComponentModel.DataAnnotations

<PageTitle>Gestão de Usuários - YUTA</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div class="page-title">
            <h1>Gestão de Usuários</h1>
            <p class="subtitle">Gerencie todos os usuários do sistema</p>
        </div>
        <button class="btn-primary" @onclick="AbrirModalCriar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Novo Usuário
        </button>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Empresa</th>
                    <th>Função</th>
                    <th>Status</th>
                    <th>Data Cadastro</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (usuarios != null && usuarios.Count > 0)
                {
                    @foreach (var usuario in usuarios)
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(usuario.FotoUrl))
                                        {
                                            <img src="@usuario.FotoUrl" alt="@usuario.Nome" />
                                        }
                                        else
                                        {
                                            <span>@usuario.Nome.Substring(0, 1).ToUpper()</span>
                                        }
                                    </div>
                                    <span>@usuario.Nome</span>
                                </div>
                            </td>
                            <td>@usuario.Email</td>
                            <td>@usuario.EmpresaId</td>
                            <td>@usuario.Role</td>
                            <td>
                                <span class="status-badge @(usuario.EmailConfirmado ? "status-active" : "status-pending")">
                                    @(usuario.EmailConfirmado ? "Ativo" : "Pendente")
                                </span>
                            </td>
                            <td>@usuario.DataCriacao.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-icon btn-edit" @onclick="() => EditarUsuario(usuario)" title="Editar">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </button>
                                    <button class="btn-icon btn-delete" @onclick="() => ExcluirUsuario(usuario)" title="Excluir">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                            <line x1="10" y1="11" x2="10" y2="17"/>
                                            <line x1="14" y1="11" x2="14" y2="17"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="no-data">Nenhum usuário encontrado</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="FecharModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(editando ? "Editar Usuário" : "Novo Usuário")</h2>
                <button class="btn-close" @onclick="FecharModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <EditForm Model="@usuarioForm" OnValidSubmit="SalvarUsuario">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>Nome Completo</label>
                    <InputText class="input-control" @bind-Value="usuarioForm.Nome" />
                    <ValidationMessage For="@(() => usuarioForm.Nome)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="input-control" @bind-Value="usuarioForm.Email" />
                    <ValidationMessage For="@(() => usuarioForm.Email)" class="text-danger" />
                </div>

                @if (!editando)
                {
                    <div class="form-group">
                        <label>Senha</label>
                        <InputText type="password" class="input-control" @bind-Value="usuarioForm.Password" />
                        <ValidationMessage For="@(() => usuarioForm.Password)" class="text-danger" />
                    </div>
                }

                <div class="form-group">
                    <label>Empresa</label>
                    <InputSelect class="input-control" @bind-Value="usuarioForm.EmpresaId">
                        <option value="0">Selecione uma empresa</option>
                        @if (empresas != null)
                        {
                            @foreach (var empresa in empresas)
                            {
                                <option value="@empresa.Id">@empresa.Nome</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => usuarioForm.EmpresaId)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>Função</label>
                    <InputSelect class="input-control" @bind-Value="usuarioForm.Role">
                        <option value="Operador">Operador</option>
                        <option value="Gerente">Gerente</option>
                        <option value="Admin">Admin</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>
                        <InputCheckbox @bind-Value="usuarioForm.EmailConfirmado" />
                        Email Confirmado
                    </label>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secondary" @onclick="FecharModal">Cancelar</button>
                    <button type="submit" class="btn-primary" disabled="@isSalvando">
                        @if (isSalvando)
                        {
                            <span>Salvando...</span>
                        }
                        else
                        {
                            <span>Salvar</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Usuario>? usuarios;
    private List<Empresa>? empresas;
    private Usuario usuarioForm = new();
    private bool mostrarModal = false;
    private bool editando = false;
    private bool isSalvando = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            usuarios = await Http.GetFromJsonAsync<List<Usuario>>("api/usuario");
            empresas = await Http.GetFromJsonAsync<List<Empresa>>("api/empresa");
        }
        catch
        {
            // Tratar erro
        }
    }

    private void AbrirModalCriar()
    {
        usuarioForm = new Usuario();
        editando = false;
        mostrarModal = true;
    }

    private void EditarUsuario(Usuario usuario)
    {
        usuarioForm = usuario;
        editando = true;
        mostrarModal = true;
    }

    private void FecharModal()
    {
        mostrarModal = false;
        usuarioForm = new Usuario();
    }

    private async Task SalvarUsuario()
    {
        isSalvando = true;
        try
        {
            // Se houver senha, copiar para PasswordHash
            if (!string.IsNullOrEmpty(usuarioForm.Password))
            {
                usuarioForm.PasswordHash = usuarioForm.Password;
            }

            if (editando)
            {
                await Http.PutAsJsonAsync($"api/usuario/{usuarioForm.Id}", usuarioForm);
            }
            else
            {
                await Http.PostAsJsonAsync("api/usuario", usuarioForm);
            }
            
            await CarregarDados();
            FecharModal();
        }
        catch
        {
            // Tratar erro
        }
        finally
        {
            isSalvando = false;
        }
    }

    private async Task ExcluirUsuario(Usuario usuario)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Deseja realmente excluir o usuário {usuario.Nome}?"))
        {
            try
            {
                await Http.DeleteAsync($"api/usuario/{usuario.Id}");
                await CarregarDados();
            }
            catch
            {
                // Tratar erro
            }
        }
    }
}